{
  "project_name": "My Django Project",
  "project_slug": "{{ cookiecutter.project_name.lower().replace(' ', '_').replace('-', '_') }}",
  "description": "A Django 6 project",
  "author_name": "Your Name",
  "author_email": "your.email@example.com",
  "python_version": "3.14.3",
  "django_version": "6.0",
  "cloud_provider": ["gcp", "aws", "both"],
  "use_custom_user_model": ["yes", "no"],
  "use_email_as_username": ["no", "yes"],
  "css_framework": ["bootstrap5", "none"],
  "use_sentry": ["yes", "no"],
  "email_backend": ["mailgun", "ses", "console"],
  "gcp_project_id": "",
  "gcp_region": "us-central1",
  "aws_region": "us-east-1",
  "database_name": "{{ cookiecutter.project_slug }}_db",
  "_copy_without_render": [
    "*.pyc",
    "*.pyo",
    "__pycache__",
    ".git",
    ".venv"
  ]
}