# Copy this file to .env for local development.
{% if cookiecutter.cloud_provider == "gcp" or cookiecutter.cloud_provider == "both" -%}
# For GCP production: store a populated copy of this file as a Secret Manager secret
# named SETTINGS_NAME (default: {{ cookiecutter.project_slug }}_settings). The app loads it
# automatically at startup when no local .env is present.
{% endif -%}

# --- Django core ---
SECRET_KEY=change-me-locally
DEBUG=1
LOCALHOST=1
DOMAIN=localhost:8000
PORT=8080

# Comma-separated list of allowed hosts.
# Local settings override this to localhost/127.0.0.1.
# Production: set to your custom domain (e.g. example.com).
{% if cookiecutter.cloud_provider == "gcp" or cookiecutter.cloud_provider == "both" -%}
# The Cloud Run *.run.app URL is added automatically via CLOUDRUN_SERVICE_URL below.
{% endif -%}
ALLOWED_HOSTS=localhost

# Must include scheme (https://). base.py auto-adds https:// if missing.
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# --- Database ---
# Local development uses SQLite — no database setup needed.
# Production (GCP): DB_HOST is the Cloud SQL Unix socket path, set automatically
# after `tofu apply`. DB_* vars take precedence over DATABASE_URL on GCP.
{% if cookiecutter.cloud_provider == "gcp" or cookiecutter.cloud_provider == "both" -%}
DB_HOST=/cloudsql/{{ cookiecutter.gcp_project_id }}:{{ cookiecutter.gcp_region }}:{{ cookiecutter.database_name }}
{% else -%}
DB_HOST=localhost
{% endif -%}
DB_USER={{ cookiecutter.project_slug }}
DB_PASSWORD=supersecretpassword
DB_NAME={{ cookiecutter.database_name }}
DB_READONLY_USER=readonly
DB_READONLY_PASSWORD=supersecretpassword
DATABASE_URL=

# --- Email ---
DEFAULT_FROM_EMAIL=noreply@example.com
SERVER_EMAIL=server@example.com
{% if cookiecutter.email_backend == "mailgun" -%}
MAILGUN_SENDER_DOMAIN=mg.example.com
MAILGUN_API_KEY=your-mailgun-api-key
{% elif cookiecutter.email_backend == "ses" -%}
# SES uses boto3. In production the App Runner IAM role provides credentials automatically.
# For local dev, set up ~/.aws/credentials or uncomment and fill in below:
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
{% endif -%}

# --- Third-party ---
SENTRY_DSN=
RECAPTCHA_PUBLIC_KEY=
RECAPTCHA_PRIVATE_KEY=
SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=your-google-oauth2-key
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=your-google-oauth2-secret

{% if cookiecutter.cloud_provider == "gcp" or cookiecutter.cloud_provider == "both" -%}
# --- GCP ---
GCP_PROJECT_ID={{ cookiecutter.gcp_project_id }}

# GCS bucket for static files and media uploads. Must be created before first deploy.
# Bucket name must be globally unique; the default matches what `tofu apply` creates.
GS_BUCKET_NAME={{ cookiecutter.project_slug }}-media
GS_DEFAULT_ACL=publicRead

# Your Cloud Run service URL (https://your-service-<hash>-uc.a.run.app).
# Available in the Cloud Run console after first deploy. When set, it is
# automatically appended to ALLOWED_HOSTS and CSRF_TRUSTED_ORIGINS.
CLOUDRUN_SERVICE_URL=

# Name of the Secret Manager secret that holds these settings in production.
SETTINGS_NAME={{ cookiecutter.project_slug }}_settings
{% endif -%}

{% if cookiecutter.cloud_provider == "aws" or cookiecutter.cloud_provider == "both" -%}
# --- AWS ---
AWS_REGION={{ cookiecutter.aws_region }}
# S3 bucket for static files and media uploads. Must match the bucket `tofu apply` creates.
AWS_STORAGE_BUCKET_NAME={{ cookiecutter.project_slug }}-media
{% endif -%}
