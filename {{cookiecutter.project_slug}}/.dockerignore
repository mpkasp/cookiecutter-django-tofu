# 1. Ignore everything by default
**

# 2. Explicitly allow only what is needed for the build
!{{ cookiecutter.project_slug }}/
!scripts/
!manage.py
!.env_example
!pyproject.toml
!uv.lock
!README.md

# 3. Re-ignore unwanted files that might sneak into the allowed directories
**/__pycache__/
**/*.py[cod]
**/.env
**/.env.*
**/db.sqlite3
**/db.sqlite3-journal
**/.DS_Store